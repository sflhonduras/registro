# Cadena de conexión a Postgres (Neon, Supabase, Railway, o local)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sfl_db

# Clave secreta para firmar tokens de sesión (usa una cadena larga y aleatoria en producción)
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# Puerto del servidor
PORT=4000

# Origen permitido para CORS (dominio del frontend en producción)
CORS_ORIGIN=http://localhost:5173
